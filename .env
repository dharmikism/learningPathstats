# Optional: set this if you do not want to paste API key in UI
FEATHERLESS_API_KEY=rc_12be697f600bf95a3c183ab625dfffb254ea3b69fb2d2164b39777963a2aba54

# Optional: change model
FEATHERLESS_MODEL=gpt-4.1-mini

# Bright Data webhook endpoint that returns stress JSON.
# Expected response shape can be one of:
# {"marketVolatility": 40, "timePressure": 55, "burnoutRisk": 45, "insight": "..."}
# or {"intel": { ...same fields... }}
BRIGHTDATA_WEBHOOK_URL=https://api.brightdata.com/request

# Optional Bearer token for your Bright Data webhook
BRIGHTDATA_BEARER_TOKEN=96510eed-6000-4b83-b5f4-ec7e96130a4f
# Required when BRIGHTDATA_WEBHOOK_URL is Bright Data Request API
BRIGHTDATA_ZONE=2nd
# Optional server port
PORT=8787
